APP_NAME=AI Chat
DEBUG=True

# Database
DATABASE_URL=postgresql://admin:admin@localhost:5432/aichat

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Upload
UPLOAD_DIR=C:\Users\<your-user>\.ai-chat\uploads
MAX_UPLOAD_SIZE_MB=20

# Text LLM
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=

# Vision model
DASH_SCOPE_API_KEY=
DASH_SCOPE_API_BASE=
VISION_MODEL=

# Embedding
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
